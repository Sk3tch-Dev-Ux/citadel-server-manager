{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30
    },
    "api/verify-subscription.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "src": "/api/webhook",
      "methods": ["POST"],
      "dest": "/api/webhook.js"
    },
    {
      "src": "/api/create-checkout",
      "methods": ["POST", "OPTIONS"],
      "dest": "/api/create-checkout.js"
    },
    {
      "src": "/api/verify-subscription",
      "methods": ["POST"],
      "dest": "/api/verify-subscription.js"
    },
    {
      "src": "/api/create-portal-session",
      "methods": ["POST"],
      "dest": "/api/create-portal-session.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/success",
      "dest": "/api/success.js"
    }
  ]
}
