# Dependencies
node_modules/

# Test coverage artifacts
coverage/

# Environment variables (contains secrets!)
.env
.env.*

# Structured config (user-specific, may contain non-default settings)
citadel.config.json

# Logs
*.log
logs/

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# IDE
.vscode/
.idea/

# SteamCMD runtime
/steamcmd/

# Backup/temp files
*.bak
*.bak.*
*.tmp

# Frontend build output
web/dist/

# VitePress docs build
docs/.vitepress/dist/
docs/.vitepress/cache/

# Runtime data (contains credentials & user data)
/data/

# JWT secret file (auto-generated, never commit)
data/.jwt-secret

# PID files
*.pid

# TLS certificates
/cert/

# DayZ mod source scripts (proprietary — not distributed)
/dayz-mod/

# Claude worktrees
/.claude/

# Cryptographic keys (NEVER commit these)
tools/license-private.pem
*.pem

# Scratch/workbench directory
/000_Scripts

# Installer build output
/build/
/desktop/dist

# Auto-updater manifest — generated by installer/build.js at build time
# and uploaded to the GitHub Release by .github/workflows/release.yml.
# Never hand-edited; never the live feed (live feed = the GitHub Release
# asset). Tracked copies have caused audit false-positives in the past.
latest.yml
