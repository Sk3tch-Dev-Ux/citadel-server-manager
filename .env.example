# ─── Citadel Configuration ─────────────────────────────
#
# AUTO-GENERATED: You do NOT need to create this file manually.
# Running `npm start` for the first time automatically generates .env
# with secure random secrets (JWT_SECRET, DISCORD_BOT_API_KEY, etc.).
#
# This .env.example is a REFERENCE showing all available options.
# Only copy this file manually if you need to customize values beyond
# what the Setup Wizard configures.
#
# IMPORTANT: Never commit .env to version control!

# API Server
PORT=3001
# AUTO-GENERATED on first run. Only set manually if you need a specific value.
JWT_SECRET=change-this-to-a-random-64-char-hex-string

# Comma-separated list of allowed CORS origins (leave empty for localhost only)
# CORS_ORIGINS=https://panel.yourdomain.com,http://localhost:3001

# Default Admin Account
# SECURITY: Admin password MUST be changed on first login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password

# DayZ Server Configuration
DAYZ_SERVER_IP=127.0.0.1
DAYZ_RCON_PORT=2305
RCON_PASSWORD=your-rcon-password-here
DAYZ_INSTALL_DIR=C:\DayZ\Server
DAYZ_PROFILE_DIR=C:\DayZ\Server\profiles
DAYZ_EXECUTABLE=DayZServer_x64.exe
DAYZ_LAUNCH_PARAMS=-config=serverDZ.cfg -port=2302 -dologs -adminlog -netlog -freezecheck

# Discord Integration (optional)
# Generate these values from your Discord Developer Portal
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CLIENT_ID=your-discord-client-id-here
DISCORD_GUILD_ID=your-discord-guild-id-here
DISCORD_ADMIN_ROLE_ID=your-admin-role-id-here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/here
# REQUIRED: Generate a strong random key (e.g. openssl rand -hex 32)
DISCORD_BOT_API_KEY=generate-a-random-32-byte-hex-string

# Panel API URL (for Discord bot to call back to the panel)
PANEL_API_URL=http://localhost:3001

# SteamCMD Integration
STEAM_USERNAME=your-steam-username
STEAM_PASSWORD=your-steam-password
STEAMCMD_PATH=C:\SteamCMD\steamcmd.exe

# InHouse Sidecar API (runs alongside your DayZ server)
# The sidecar + DayZ mod handle player data, bans, leaderboards, and admin actions.
# Configure per-server in the web panel: inHouseApiUrl and inHouseApiKey
# INHOUSE_SIDECAR_PORT=9100
# INHOUSE_API_KEY=generate-a-random-key

# Legacy Integration (optional, most users don't need this)
# CFTOOLS_APPLICATION_ID=your-app-id
# CFTOOLS_SECRET=your-secret

# Citadel Cloud Integration (optional)
# Connect to Citadel Cloud for remote dashboard, mobile access, and cross-server intelligence.
# API keys are configured per-server in the web panel under Cloud settings.
# CLOUD_ENABLED=false
# CLOUD_RELAY_URL=wss://cloud.citadel.cc
