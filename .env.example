# ─── Citadel Agent Configuration ───────────────────────────
# Copy this file to `.env` and fill in the values, OR just run the app once and
# the Setup Wizard generates a secure `.env` for you automatically.
#
# Every value below is a PLACEHOLDER — never commit real secrets. Secrets you
# leave unset are either auto-generated (JWT_SECRET, DISCORD_BOT_API_KEY) or
# fall back to safe defaults. Most settings can also live in citadel.config.json;
# anything set here in .env always wins.

# ─── API Server ────────────────────────────────────────────
# PORT                API server / dashboard port (default: 3001)
# BIND_HOST           Interface to bind. Default 127.0.0.1 (loopback only) — the
#                     Agent is meant to be reached locally; use Citadel Cloud for
#                     remote access. 0.0.0.0 exposes the dashboard to the LAN and
#                     logs a security warning.
# CORS_ORIGINS        Comma-separated list of allowed browser origins.
# TRUSTED_PROXIES     Comma-separated reverse-proxy IPs to trust (X-Forwarded-For).
PORT=3001
BIND_HOST=127.0.0.1
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
# TRUSTED_PROXIES=

# ─── Auth ──────────────────────────────────────────────────
# JWT_SECRET          Signing secret for auth tokens. Leave blank/unset and the
#                     app auto-generates one and persists it to data/.jwt-secret.
# JWT_EXPIRES_IN      Token lifetime, e.g. 8h, 24h, 7d (default: 24h).
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRES_IN=24h

# ─── Admin Account ─────────────────────────────────────────
# The Setup Wizard replaces these on first run with the credentials you choose.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password

# ─── DayZ Server ───────────────────────────────────────────
# Usually configured through the Setup Wizard / Servers page rather than here.
DAYZ_SERVER_IP=127.0.0.1
DAYZ_INSTALL_DIR=
# DAYZ_PROFILE_DIR=
# DAYZ_RCON_PORT=2305
# RCON_PASSWORD=
# DAYZ_EXECUTABLE=DayZServer_x64.exe
# DAYZ_LAUNCH_PARAMS=-config=serverDZ.cfg -port=2302 -profiles=profiles -dologs -adminlog -netlog -freezecheck

# ─── SteamCMD ──────────────────────────────────────────────
# Auto-detected or configured via the Setup Wizard.
# STEAMCMD_PATH=
# STEAM_USERNAME=
# STEAM_PASSWORD=

# ─── Discord Bot (optional) ────────────────────────────────
# The Discord bot now ships in the separate citadel-bot repo / Citadel Cloud —
# the Agent no longer launches it. These vars are still read by the Agent's
# /api/discord/* surface (DISCORD_BOT_API_KEY) and by the deprecated in-Agent
# spawn path. DISCORD_BOT_API_KEY auto-generates if left as the placeholder.
# DISCORD_BOT_TOKEN=
# DISCORD_CLIENT_ID=
# DISCORD_GUILD_ID=
# DISCORD_ADMIN_ROLE_ID=
# DISCORD_WEBHOOK_URL=
DISCORD_BOT_API_KEY=change-this-to-a-random-key
# CITADEL_AGENT_SPAWN_BOT  Deprecated legacy escape hatch. Set to 1 to make the
#                          Agent spawn a bundled discord-bot/ as a child process
#                          (from-source installs only; not bundled in the installer).
# CITADEL_AGENT_SPAWN_BOT=0

# ─── Bans ──────────────────────────────────────────────────
# BAN_KICK_MESSAGE   Kick message template. Supports {reason} and {banId}.
# BAN_APPEAL_URL     Discord invite / appeal URL shown in ban kick messages.
# BAN_KICK_MESSAGE=You have been banned. Reason: {reason}. To appeal, visit our Discord.
# BAN_APPEAL_URL=

# ─── Logging & Data ────────────────────────────────────────
# LOG_LEVEL          trace | debug | info | warn | error | fatal (default: info)
# CITADEL_DATA_DIR   Data directory for JSON persistence (default: ./data)
# LOG_LEVEL=info
# CITADEL_DATA_DIR=./data

# ─── Legacy Integration (optional, most users don't need this) ──
# CFTOOLS_APPLICATION_ID=
# CFTOOLS_SECRET=
