# ─── DayZ Panel Configuration ───────────────────────────
# Copy this file to .env and fill in your values

# API Server
PORT=3001
# REQUIRED: Generate a strong random secret (e.g. openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-me
# Comma-separated list of allowed origins for CORS (leave empty for localhost only)
# CORS_ORIGINS=https://panel.yourdomain.com,http://localhost:3001

# Default Admin Account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# DayZ Server
DAYZ_SERVER_IP=127.0.0.1
DAYZ_RCON_PORT=2305
RCON_PASSWORD=your-rcon-password
DAYZ_INSTALL_DIR=/home/dayz/server
DAYZ_PROFILE_DIR=/home/dayz/server/profiles
DAYZ_EXECUTABLE=DayZServer_x64.exe
DAYZ_LAUNCH_PARAMS=-config=serverDZ.cfg -port=2302 -dologs -adminlog -netlog -freezecheck

# Discord Integration
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_GUILD_ID=your-discord-guild-id
DISCORD_ADMIN_ROLE_ID=your-admin-role-id
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook
# REQUIRED: Generate a strong random key (e.g. openssl rand -hex 32)
DISCORD_BOT_API_KEY=change-this-to-a-random-key

# Panel API URL (for Discord bot to call)
PANEL_API_URL=http://localhost:3001
