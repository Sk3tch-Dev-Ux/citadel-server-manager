{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AILocationSettings",
  "type": "object",
  "x-source": "dayzexpansion.com",
  "x-modId": "expansion-ai",
  "x-filePath": "mpmissions/empty.chernarusplus/expansion/settings/AILocationSettings.json",
  "properties": {
    "m_Version": {
      "description": "M_version",
      "examples": [
        "4"
      ],
      "type": "integer",
      "default": 4
    },
    "RoamingLocations": {
      "description": "Roaming locations",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Name": {
            "description": "DayZ classname (e.g. \"Settlement_Chernogorsk\")",
            "examples": [
              "\"Settlement_Chernogorsk\""
            ],
            "type": "string",
            "format": "dayz-classname",
            "default": "Settlement_Chernogorsk"
          },
          "Position": {
            "description": "Position",
            "examples": [
              "6778.619140625, 0, 2321.77392578125"
            ],
            "type": "string",
            "format": "vector3",
            "default": "6778.619140625, 0, 2321.77392578125"
          },
          "Radius": {
            "description": "Radius (default: 1000)",
            "examples": [
              "1000"
            ],
            "type": "integer",
            "default": 1000
          },
          "Type": {
            "description": "Type",
            "examples": [
              "\"Capital\""
            ],
            "type": "string",
            "default": "Capital"
          },
          "Enabled": {
            "description": "Enable or disable d",
            "examples": [
              "1"
            ],
            "type": "integer",
            "enum": [
              0,
              1
            ],
            "default": 1
          }
        }
      },
      "default": []
    },
    "ExcludedRoamingBuildings": {
      "description": "Excluded roaming buildings",
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "NoGoAreas": {
      "description": "No go areas",
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
