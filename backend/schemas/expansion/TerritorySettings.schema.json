{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TerritorySettings",
  "type": "object",
  "x-source": "dayzexpansion.com",
  "x-modId": "expansion-basebuilding",
  "x-filePath": "Profiles/ExpansionMod/Settings/TerritorySettings.json",
  "properties": {
    "m_Version": {
      "description": "M_version",
      "examples": [
        "6"
      ],
      "type": "integer",
      "default": 6
    },
    "EnableTerritories": {
      "description": "Enable or disable territories",
      "examples": [
        "1"
      ],
      "type": "integer",
      "enum": [
        0,
        1
      ],
      "default": 1
    },
    "UseWholeMapForInviteList": {
      "description": "Enable or disable whole map for invite list",
      "examples": [
        "0"
      ],
      "type": "integer",
      "enum": [
        0,
        1
      ],
      "default": 0
    },
    "TerritorySize": {
      "description": "Territory size (default: 150)",
      "examples": [
        "150"
      ],
      "type": "integer",
      "default": 150
    },
    "TerritoryPerimeterSize": {
      "description": "Territory perimeter size (default: 150)",
      "examples": [
        "150"
      ],
      "type": "integer",
      "default": 150
    },
    "MaxMembersInTerritory": {
      "description": "Max members in territory",
      "examples": [
        "10"
      ],
      "type": "integer",
      "default": 10
    },
    "MaxTerritoryPerPlayer": {
      "description": "Max territory per player",
      "examples": [
        "1"
      ],
      "type": "integer",
      "default": 1
    },
    "TerritoryInviteAcceptRadius": {
      "description": "Territory invite accept radius (default: 150)",
      "examples": [
        "150"
      ],
      "type": "integer",
      "default": 150
    },
    "AuthenticateCodeLockIfTerritoryMember": {
      "description": "Authenticate code lock if territory member",
      "examples": [
        "0"
      ],
      "type": "integer",
      "enum": [
        0,
        1
      ],
      "default": 0
    },
    "InviteCooldown": {
      "description": "Invite cooldown",
      "examples": [
        "0"
      ],
      "type": "integer",
      "default": 0
    },
    "OnlyInviteGroupMember": {
      "description": "Only invite group member",
      "examples": [
        "0"
      ],
      "type": "integer",
      "enum": [
        0,
        1
      ],
      "default": 0
    },
    "MaxCodeLocksOnBBPerTerritory": {
      "description": "Max code locks on bb per territory",
      "examples": [
        "-1"
      ],
      "type": "integer",
      "default": -1
    },
    "MaxCodeLocksOnItemsPerTerritory": {
      "description": "Max code locks on items per territory",
      "examples": [
        "-1"
      ],
      "type": "integer",
      "default": -1
    }
  }
}
