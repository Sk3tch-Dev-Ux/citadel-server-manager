{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GeneralSettings",
  "type": "object",
  "x-source": "dayzexpansion.com",
  "x-modId": "expansion-main",
  "x-filePath": "Profiles/ExpansionMod/Settings/GeneralSettings.json",
  "properties": {
    "m_Version": {
      "description": "M_version",
      "examples": [
        "16"
      ],
      "type": "integer",
      "default": 16
    },
    "DisableShootToUnlock": {
      "description": "Enable or disable shoot to unlock",
      "examples": [
        "0"
      ],
      "type": "integer",
      "enum": [
        0,
        1
      ],
      "default": 0
    },
    "EnableGravecross": {
      "description": "Enable or disable gravecross",
      "examples": [
        "0"
      ],
      "type": "integer",
      "enum": [
        0,
        1
      ],
      "default": 0
    },
    "EnableAIGravecross": {
      "description": "Enable or disable ai gravecross",
      "examples": [
        "0"
      ],
      "type": "integer",
      "enum": [
        0,
        1
      ],
      "default": 0
    },
    "GravecrossDeleteBody": {
      "description": "Gravecross delete body",
      "examples": [
        "1"
      ],
      "type": "integer",
      "default": 1
    },
    "GravecrossTimeThreshold": {
      "description": "Gravecross time threshold (default: 1200)",
      "examples": [
        "1200"
      ],
      "type": "integer",
      "default": 1200
    },
    "GravecrossSpawnTimeDelay": {
      "description": "Gravecross spawn time delay (default: 180)",
      "examples": [
        "180"
      ],
      "type": "integer",
      "default": 180
    },
    "Mapping": {
      "description": "Mapping",
      "type": "object",
      "properties": {
        "UseCustomMappingModule": {
          "description": "Enable or disable custom mapping module",
          "examples": [
            "0"
          ],
          "type": "integer",
          "enum": [
            0,
            1
          ],
          "default": 0
        },
        "Mapping": {
          "description": "Mapping",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "BuildingInteriors": {
          "description": "Building interiors",
          "examples": [
            "0"
          ],
          "type": "integer",
          "default": 0
        },
        "Interiors": {
          "description": "Interiors",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "BuildingIvys": {
          "description": "Building ivys",
          "examples": [
            "0"
          ],
          "type": "integer",
          "default": 0
        }
      },
      "default": {}
    },
    "EnableLamps": {
      "description": "0 - Disable Street-Lights | 1 - Will use and spawn Generators for Street-Lights | 2 - Street-Lights always on",
      "examples": [
        "3"
      ],
      "type": "integer",
      "default": 3
    },
    "LampAmount_OneInX": {
      "description": "Lamp amount_one in x",
      "examples": [
        "3"
      ],
      "type": "integer",
      "default": 3
    },
    "LampSelectionMode": {
      "description": "How lamps with lights are distributed across the map",
      "examples": [
        "\"FARTHEST_RANDOM\""
      ],
      "type": "string",
      "enum": [
        "RANDOM",
        "FARTHEST",
        "FARTHEST_RANDOM"
      ],
      "x-enumLabels": {
        "RANDOM": "RANDOM (Completely random, may flicker)",
        "FARTHEST": "FARTHEST (Optimized farthest point sampling)",
        "FARTHEST_RANDOM": "FARTHEST_RANDOM (OFPS with random distribution)"
      },
      "default": "FARTHEST_RANDOM"
    },
    "EnableGenerators": {
      "description": "Enable or disable generators",
      "examples": [
        "0"
      ],
      "type": "integer",
      "enum": [
        0,
        1
      ],
      "default": 0
