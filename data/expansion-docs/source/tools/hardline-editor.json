{
  "id": "hardline-editor",
  "name": "Hardline Editor",
  "description": "Configure Expansion Hardline settings — reputation, item rarity tiers, entity values, and market gating. Generates HardlineSettings.json.",
  "iconName": "Shield",
  "keywords": [
    "hardline",
    "reputation",
    "rarity",
    "faction",
    "entity",
    "market",
    "progression"
  ],
  "enabled": true,
  "toolType": "official",
  "isVisual": true,
  "outputModes": [
    "generate"
  ],
  "downloadFilename": "HardlineSettings.json",
  "tabIcons": {
    "General": "Settings",
    "Entities": "Users",
    "Reputation": "Shield",
    "Item Rarity": "Gem"
  },
  "formFields": [
    {
      "id": "hl-v1",
      "key": "m_Version",
      "tab": "General",
      "type": "number",
      "group": "System Toggles",
      "label": "Config Version",
      "colSpan": 4,
      "readOnly": false,
      "description": "m_Version — auto-increments on each export. Usually 10 for current Expansion.",
      "defaultValue": "10"
    },
    {
      "id": "hl-t1",
      "key": "ShowHardlineHUD",
      "tab": "General",
      "type": "boolean",
      "group": "System Toggles",
      "label": "Show Hardline HUD",
      "colSpan": 2,
      "description": "Show reputation indicator in the main HUD",
      "defaultValue": "true"
    },
    {
      "id": "hl-t2",
      "key": "UseReputation",
      "tab": "General",
      "type": "boolean",
      "group": "System Toggles",
      "label": "Use Reputation",
      "colSpan": 2,
      "description": "Enable hardline reputation — players gain/lose points from actions",
      "defaultValue": "true"
    },
    {
      "id": "hl-t3",
      "key": "UseFactionReputation",
      "tab": "General",
      "type": "boolean",
      "group": "System Toggles",
      "label": "Use Faction Reputation",
      "colSpan": 2,
      "description": "Track reputation individually per eAIFaction",
      "defaultValue": "true"
    },
    {
      "id": "hl-t4",
      "key": "EnableFactionPersistence",
      "tab": "General",
      "type": "boolean",
      "group": "System Toggles",
      "label": "Enable Faction Persistence",
      "colSpan": 2,
      "description": "Keep faction assignment across server restarts",
      "defaultValue": "true"
    },
    {
      "id": "hl-t5",
      "key": "EnableItemRarity",
      "tab": "General",
      "type": "boolean",
      "group": "System Toggles",
      "label": "Enable Item Rarity",
      "colSpan": 2,
      "description": "Display rarity on items in tooltips and icons",
      "defaultValue": "true"
    },
    {
      "id": "hl-t6",
      "key": "UseItemRarityOnInventoryIcons",
      "tab": "General",
      "type": "boolean",
      "group": "System Toggles",
      "label": "Rarity on Inventory Icons",
      "colSpan": 2,
      "description": "Colorize inventory icons and slots with rarity color",
      "defaultValue": "true"
    },
    {
      "id": "hl-t7",
      "key": "UseItemRarityForMarketPurchase",
      "tab": "General",
      "type": "boolean",
      "group": "System Toggles",
      "label": "Rarity for Market Buy",
      "colSpan": 2,
      "description": "Require minimum reputation to BUY items from market",
      "defaultValue": "false"
    },
    {
      "id": "hl-t8",
      "key": "UseItemRarityForMarketSell",
      "tab": "General",
      "type": "boolean",
      "group": "System Toggles",
      "label": "Rarity for Market Sell",
      "colSpan": 2,
      "description": "Require minimum reputation to SELL items at market",
      "defaultValue": "false"
    },
    {
      "id": "hl-p1",
      "key": "MaxReputation",
      "tab": "General",
      "type": "number",
      "group": "Parameters",
      "label": "Max Reputation",
      "colSpan": 2,
      "description": "Maximum reputation a player can reach (int32 max)",
      "defaultValue": "2147483647",
      "validationRules": [
        {
          "type": "min",
          "value": "0",
          "message": "Must be ≥ 0"
        },
        {
          "type": "max",
          "value": "2147483647",
          "message": "Must be ≤ 2147483647"
        }
      ]
    },
    {
      "id": "hl-p2",
      "key": "ReputationLossOnDeath",
      "tab": "General",
      "type": "number",
      "group": "Parameters",
      "label": "Reputation Loss on Death",
      "colSpan": 2,
      "description": "Points lost when killed by another player/entity",
      "defaultValue": "100",
      "validationRules": [
        {
          "type": "min",
          "value": "-2147483647",
          "message": "Must be ≥ -2147483647"
        },
        {
          "type": "max",
          "value": "2147483647",
          "message": "Must be ≤ 2147483647"
        }
      ]
    },
    {
      "id": "hl-p3",
      "key": "DefaultItemRarity",
      "tab": "General",
      "type": "select",
      "group": "Parameters",
      "label": "Default Item Rarity",
      "colSpan": 2,
      "options": [
        "1",
        "2",
        "3",
        "4",
        "5",
        "6",
        "7",
        "8"
      ],
      "description": "Fallback rarity for items not listed in ItemRarity table",
      "defaultValue": "2",
      "optionColors": [
        "#808080",
        "#4caf6e",
        "#42a5f5",
        "#ab47bc",
        "#ff7043",
        "#ffd54f",
        "#ef5350",
        "#26c6da"
      ],
      "optionLabels": [
        "Poor",
        "Common",
        "Uncommon",
        "Rare",
        "Epic",
        "Legendary",
        "Mythic",
        "Exotic"
      ]
    },
    {
      "id": "hl-r1",
      "key": "PoorItemRequirement",
      "tab": "Reputation",
      "type": "number",
      "group": "Rarity Reputation Requirements",
      "label": "Poor Requirement",
      "colSpan": 1,
      "description": "Min reputation to buy/sell Poor items (0 = unrestricted)",
      "defaultValue": "0",
      "optionColors": [
        "#808080"
      ]
    },
    {
      "id": "hl-r2",
      "key": "CommonItemRequirement",
