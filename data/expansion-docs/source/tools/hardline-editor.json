  "tutorialSteps": [
    {
      "title": "⚙️ System Toggles",
      "targetTab": "General",
      "description": "Enable or disable core features: UseReputation, EnableItemRarity, UseFactionReputation, and more.",
      "highlightSelector": "[data-tutorial='hl-sec-toggles']"
    },
    {
      "title": "⚙️ Global Parameters",
      "targetTab": "General",
      "description": "Set MaxReputation (cap), ReputationLossOnDeath, and DefaultItemRarity (fallback for unlisted items).",
      "highlightSelector": "[data-tutorial='hl-sec-params']"
    },
    {
      "title": "🛡️ Reputation Thresholds",
      "targetTab": "Reputation",
      "description": "Set minimum reputation to buy/sell items of each rarity tier. Set to 0 for unrestricted access.",
      "highlightSelector": "[data-tutorial='hl-sec-req']"
    },
    {
      "title": "💎 Item Rarity Table",
      "targetTab": "Item Rarity",
      "description": "Assign rarity tiers to item classnames. Use the search bar, filters, and bulk actions to manage large lists.",
      "highlightSelector": "[data-tutorial='hl-sec-ir']"
    },
    {
      "title": "📥 Bulk Import",
      "targetTab": "Item Rarity",
      "description": "Use the Import button to paste classname lists or load a types.xml file with automatic nominal→rarity mapping.",
      "highlightSelector": "[data-tutorial='hl-ir-add']"
    },
    {
      "title": "👾 Entity Kill Rewards",
      "targetTab": "Entities",
      "description": "Configure reputation points gained/lost for killing entities. Use base classes (ZombieBase) for broad rules.",
      "highlightSelector": "[data-tutorial='hl-sec-ent']"
