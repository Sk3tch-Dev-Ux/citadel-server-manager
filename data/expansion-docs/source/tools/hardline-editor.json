      "type": "number",
      "group": "Rarity Reputation Requirements",
      "label": "Exotic Requirement",
      "colSpan": 2,
      "description": "Min reputation to buy/sell Exotic items",
      "defaultValue": "5000",
      "optionColors": [
        "#26c6da"
      ]
    },
    {
      "id": "hl-ir1",
      "key": "ItemRarity",
      "tab": "Item Rarity",
      "type": "repeater",
      "group": "Item Rarity Table",
      "label": "Item Rarity Assignments",
      "colSpan": 4,
      "richTable": true,
      "subFields": [
        {
          "id": "hlir1",
          "key": "name",
          "type": "text",
          "label": "Classname",
          "placeholder": "e.g. m4a1",
          "autocomplete": true,
          "defaultValue": ""
        },
        {
          "id": "hlir2",
          "key": "rarity",
          "type": "select",
          "label": "Rarity",
          "options": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "defaultValue": "2",
          "optionColors": [
            "#808080",
            "#4caf6e",
            "#42a5f5",
            "#ab47bc",
            "#ff7043",
            "#ffd54f",
            "#ef5350",
            "#26c6da"
          ],
          "optionLabels": [
            "Poor",
            "Common",
            "Uncommon",
            "Rare",
            "Epic",
            "Legendary",
            "Mythic",
            "Exotic"
          ]
        }
      ],
      "description": "Assign rarity tiers to specific item classnames. Items not listed use the default rarity.",
      "autocomplete": true,
      "defaultValue": "[]"
    },
    {
      "id": "hl-e1",
      "key": "EntityReputation",
      "tab": "Entities",
      "type": "repeater",
      "group": "Entity Reputation",
      "label": "Entity Reputation Values",
      "colSpan": 4,
      "richTable": true,
      "subFields": [
        {
          "id": "hle1",
          "key": "name",
          "type": "text",
          "label": "Entity Class",
          "placeholder": "e.g. ZombieBase",
          "autocomplete": true,
          "defaultValue": ""
        },
        {
          "id": "hle2",
          "key": "value",
          "type": "number",
          "label": "Rep Value",
          "defaultValue": "10"
        }
      ],
      "description": "Reputation points gained/lost for killing each entity type",
      "autocomplete": true,
      "defaultValue": "[{\"name\":\"ZombieBase\",\"value\":\"10\"},{\"name\":\"PlayerBase\",\"value\":\"100\"},{\"name\":\"AnimalBase\",\"value\":\"5\"},{\"name\":\"eAIBase\",\"value\":\"50\"},{\"name\":\"ZmbM_NBC_Grey\",\"value\":\"20\"}]"
    }
