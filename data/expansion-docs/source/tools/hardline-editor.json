      "type": "number",
      "group": "Rarity Reputation Requirements",
      "label": "Legendary Requirement",
      "colSpan": 2,
      "description": "Min reputation to buy/sell Legendary items",
      "defaultValue": "1000",
      "optionColors": [
        "#ffd54f"
      ]
    },
    {
      "id": "hl-r7",
      "key": "MythicItemRequirement",
      "tab": "Reputation",
      "type": "number",
      "group": "Rarity Reputation Requirements",
      "label": "Mythic Requirement",
      "colSpan": 2,
