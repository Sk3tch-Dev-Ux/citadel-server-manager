{
  "id": "argb-calculator",
  "name": "ARGB ↔ Int",
  "description": "Convert between ARGB color values and signed 32-bit integer representations used in DayZ configs. Includes a visual color picker and reverse integer-to-RGBA conversion.",
  "iconName": "Palette",
  "keywords": [
    "color",
    "argb",
    "integer",
    "convert",
    "hex",
    "rgba",
    "picker"
  ],
  "enabled": true,
  "isVisual": true,
  "outputModes": [
    "calculator"
  ],
  "formFields": [
    {
      "id": "f0",
      "key": "pickerColor",
      "type": "color",
      "group": "Color Picker",
      "label": "Color Picker",
      "colSpan": 4,
      "description": "Pick a color visually - channel sliders below update automatically",
      "defaultValue": "#ffffff",
      "syncToFields": {
        "b": "parseInt('{{value}}'.replace('#','').substring(4,6), 16) || 0",
        "g": "parseInt('{{value}}'.replace('#','').substring(2,4), 16) || 0",
        "r": "parseInt('{{value}}'.replace('#','').substring(0,2), 16) || 0"
      }
    },
    {
      "id": "f1",
      "key": "r",
      "type": "slider",
      "group": "Channels",
      "label": "Red",
      "colSpan": 1,
      "defaultValue": "255",
      "sliderConfig": {
        "max": 255,
        "min": 0,
        "step": 1
      },
      "validationRules": [
        {
          "type": "min",
          "value": "0",
          "message": "Must be 0–255"
        },
        {
          "type": "max",
          "value": "255",
          "message": "Must be 0–255"
        }
      ]
    },
    {
      "id": "f2",
      "key": "g",
      "type": "slider",
      "group": "Channels",
      "label": "Green",
      "colSpan": 1,
      "defaultValue": "255",
      "sliderConfig": {
        "max": 255,
        "min": 0,
        "step": 1
      },
      "validationRules": [
        {
          "type": "min",
          "value": "0",
          "message": "Must be 0–255"
        },
        {
          "type": "max",
          "value": "255",
          "message": "Must be 0–255"
        }
      ]
    },
    {
      "id": "f3",
      "key": "b",
      "type": "slider",
      "group": "Channels",
      "label": "Blue",
      "colSpan": 1,
      "defaultValue": "255",
      "sliderConfig": {
        "max": 255,
        "min": 0,
        "step": 1
      },
      "validationRules": [
        {
          "type": "min",
          "value": "0",
          "message": "Must be 0–255"
        },
        {
          "type": "max",
          "value": "255",
          "message": "Must be 0–255"
        }
      ]
    },
    {
      "id": "f4",
      "key": "a",
      "type": "slider",
      "group": "Channels",
      "label": "Alpha",
      "colSpan": 1,
      "defaultValue": "255",
      "sliderConfig": {
        "max": 255,
        "min": 0,
        "step": 1
      },
      "validationRules": [
        {
          "type": "min",
          "value": "0",
          "message": "Must be 0–255"
        },
        {
          "type": "max",
          "value": "255",
          "message": "Must be 0–255"
        }
      ]
    },
    {
      "id": "f5",
      "key": "integerInput",
      "type": "text",
      "group": "Reverse Conversion",
      "label": "Integer to RGBA",
      "colSpan": 4,
      "description": "Paste a signed 32-bit integer (e.g. -1 or -16777216) to convert back to RGBA channels",
      "placeholder": "e.g. -1 or -16777216",
      "defaultValue": "",
      "syncToFields": {
        "a": "((parseInt('{{value}}') || 0) >>> 24) & 255",
        "b": "(parseInt('{{value}}') || 0) & 255",
        "g": "((parseInt('{{value}}') || 0) >>> 8) & 255",
        "r": "((parseInt('{{value}}') || 0) >>> 16) & 255"
      }
    }
  ],
  "tutorialSteps": [
    {
      "title": "🎨 Color Picker & Channels",
      "description": "Use the color picker to select a color visually, or adjust individual RGBA channels with the sliders below. Changes sync automatically.",
      "highlightSelector": "[data-tutorial='ac-left']"
    },
    {
      "title": "🔢 Integer Output",
      "demoValues": {
        "a": "255",
        "b": "255",
        "g": "0",
        "r": "128"
      },
      "description": "The calculator converts your RGBA values to a signed 32-bit integer used in DayZ configs (e.g. ARGB color fields in Expansion settings).",
      "highlightSelector": "[data-tutorial='ac-right']"
    },
    {
      "title": "🔄 Reverse Conversion",
      "demoValues": {
        "a": "255",
        "b": "255",
        "g": "255",
        "r": "255"
      },
      "description": "Paste a signed integer (e.g. -1 or -16777216) into the 'Integer to RGBA' field to convert it back to individual RGBA channels.",
      "highlightSelector": "[data-tutorial='ac-sec-reverse']"
    }
  ],
