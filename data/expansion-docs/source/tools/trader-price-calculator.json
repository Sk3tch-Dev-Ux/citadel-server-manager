      },
      {
        "id": "n20",
        "type": "lookup",
        "position": {
          "x": 0,
          "y": 0
        },
        "data": {
          "label": "Condition Mod",
          "outputKey": "condMod",
          "expression": "{\"Pristine\":1,\"Worn\":0.75,\"Damaged\":0.5,\"Badly Damaged\":0.25,\"Ruined\":0}"
        }
      },
      {
        "id": "n21",
        "type": "lookup",
        "position": {
          "x": 0,
          "y": 0
        },
        "data": {
          "label": "Food Stage Mod",
          "outputKey": "foodMod",
          "expression": "{\"raw\":1,\"baked\":0.75,\"boiled\":0.5,\"dried\":0.25,\"burned\":0,\"rotten\":0}"
        }
      },
      {
        "id": "n23",
        "type": "formula",
        "position": {
          "x": 0,
          "y": 0
        },
        "data": {
          "label": "Quantity Mod",
          "outputKey": "quantityMod",
          "expression": "max(0, min(1, {{quantityRatio}} / 100))"
        }
      },
      {
        "id": "n30",
        "type": "math",
        "position": {
          "x": 0,
          "y": 0
        },
        "data": {
          "label": "Stock Range",
          "outputKey": "stockRange",
          "expression": "max(1, {{maxStock}} - {{minStock}})"
        }
      },
      {
        "id": "n31",
        "type": "math",
        "position": {
          "x": 0,
          "y": 0
        },
        "data": {
          "label": "Price Range",
          "outputKey": "priceRange",
          "expression": "{{minPrice}} - {{maxPrice}}"
        }
      },
      {
        "id": "n32",
        "type": "formula",
        "position": {
          "x": 0,
          "y": 0
        },
        "data": {
          "label": "Buy @ Min Stock",
          "outputKey": "buyAtMinStock",
          "expression": "round({{maxPrice}} * {{buyPercent}} / 100)"
        }
      },
      {
        "id": "n33",
        "type": "math",
        "position": {
          "x": 0,
          "y": 0
        },
        "data": {
          "label": "Sell Modifier",
          "outputKey": "sellMod",
          "expression": "{{condMod}} * {{quantityMod}} * {{foodMod}}"
        }
      },
      {
        "id": "n34",
        "type": "formula",
        "position": {
          "x": 0,
          "y": 0
        },
        "data": {
          "label": "Sell @ Min Stock",
          "outputKey": "sellAtMinStock",
          "expression": "round({{buyAtMinStock}} * {{sellPercent}} / 100 * {{sellMod}})"
        }
      },
      {
        "id": "n35",
        "type": "formula",
        "position": {
          "x": 0,
          "y": 0
        },
        "data": {
          "label": "Spread",
          "outputKey": "spread",
          "expression": "{{buyAtMinStock}} - {{sellAtMinStock}}"
        }
      },
