{
  "id": "trader-price-calculator",
  "name": "Price Calculator",
  "description": "Visualize dynamic pricing curves based on stock thresholds and item modifiers. Replicates the exact sell/buy price logic from ExpansionMarketModule.",
  "iconName": "TrendingUp",
  "keywords": [
    "trader",
    "price",
    "stock",
    "economy",
    "curve",
    "modifier"
  ],
  "enabled": true,
  "isVisual": true,
  "outputModes": [
    "calculator"
  ],
  "formFields": [
    {
      "id": "f1",
      "key": "minPrice",
      "type": "number",
      "group": "Item Config",
      "label": "Min Price",
      "colSpan": 2,
      "required": true,
      "description": "MinPriceThreshold — buy price at max stock (abundant = cheap)",
      "placeholder": "e.g. 100",
      "defaultValue": "100",
      "validationRules": [
        {
          "type": "min",
          "value": "0",
          "message": "Must be ≥ 0"
        }
      ]
    },
    {
      "id": "f2",
      "key": "maxPrice",
      "type": "number",
      "group": "Item Config",
      "label": "Max Price",
      "colSpan": 2,
      "required": true,
      "description": "MaxPriceThreshold — buy price at min stock (scarce = expensive)",
      "placeholder": "e.g. 1000",
      "defaultValue": "1000",
      "validationRules": [
        {
          "type": "min",
          "value": "0",
          "message": "Must be ≥ 0"
        }
      ]
    },
    {
      "id": "f3",
      "key": "minStock",
      "type": "number",
      "group": "Item Config",
      "label": "Min Stock",
      "colSpan": 2,
      "required": true,
      "description": "MinStockThreshold — stock level where price is at maximum",
      "placeholder": "e.g. 1",
      "defaultValue": "1",
      "validationRules": [
        {
          "type": "min",
          "value": "0",
          "message": "Must be ≥ 0"
        }
      ]
    },
    {
      "id": "f4",
      "key": "maxStock",
      "type": "number",
      "group": "Item Config",
      "label": "Max Stock",
      "colSpan": 2,
      "required": true,
      "description": "MaxStockThreshold — stock level where price is at minimum",
      "placeholder": "e.g. 100",
      "defaultValue": "100",
      "validationRules": [
        {
          "type": "min",
          "value": "1",
          "message": "Must be ≥ 1"
        }
      ]
    },
    {
      "id": "f5",
      "key": "sellPercent",
      "type": "slider",
      "group": "Zone / Global Config",
      "label": "Sell Price %",
      "colSpan": 2,
      "description": "Base sell price as % of buy price. -1 = not sellable; other negative values are also valid (e.g. inverse pricing).",
      "defaultValue": "50",
      "sliderConfig": {
        "max": 200,
        "min": -200,
        "step": 1
      }
    },
    {
      "id": "f6",
      "key": "buyPercent",
      "type": "slider",
      "group": "Zone / Global Config",
      "label": "Buy Price %",
      "colSpan": 2,
      "description": "Zone-level modifier applied to all buy prices. Negative values are valid.",
      "defaultValue": "100",
      "sliderConfig": {
        "max": 200,
        "min": -200,
        "step": 1
      }
    },
    {
      "id": "f7",
      "key": "condition",
      "type": "select",
      "group": "Sell Modifiers",
      "label": "Condition",
      "colSpan": 2,
      "options": [
        "Pristine",
        "Worn",
        "Damaged",
        "Badly Damaged",
        "Ruined"
      ],
      "defaultValue": "Pristine",
      "optionColors": [
        "#4caf6e",
        "#42a5f5",
        "#ff7043",
        "#ef5350",
        "#808080"
      ],
      "optionLabels": [
        "Pristine (×1.00)",
        "Worn (×0.75)",
        "Damaged (×0.50)",
        "Badly Damaged (×0.25)",
        "Ruined (×0.00)"
      ]
    },
    {
      "id": "f8",
      "key": "quantityRatio",
      "type": "slider",
      "group": "Sell Modifiers",
      "label": "Quantity %",
      "colSpan": 2,
      "description": "Current quantity / max quantity (%)",
      "defaultValue": "100",
      "sliderConfig": {
        "max": 100,
        "min": 0,
        "step": 1
      }
    },
    {
      "id": "f9",
      "key": "isEdible",
      "type": "boolean",
      "group": "Sell Modifiers",
      "label": "Edible / Food Item",
      "colSpan": 2,
      "defaultValue": "false"
    },
    {
      "id": "f10",
      "key": "destroyOnMin",
      "type": "boolean",
      "group": "Sell Modifiers",
      "label": "Destroy on Min Qty",
      "colSpan": 2,
      "conditions": [
        {
          "value": "true",
          "fieldKey": "isEdible",
          "operator": "eq"
        }
      ],
      "description": "If false, minimum sell factor is 0.25 instead of 0",
      "defaultValue": "true"
    },
    {
      "id": "f11",
      "key": "foodStage",
      "type": "select",
      "group": "Sell Modifiers",
      "label": "Food Stage",
      "colSpan": 2,
      "options": [
        "raw",
        "baked",
        "boiled",
        "dried",
        "burned",
        "rotten"
      ],
      "conditions": [
        {
          "value": "true",
          "fieldKey": "isEdible",
          "operator": "eq"
        }
      ],
      "defaultValue": "raw",
      "optionColors": [
        "#4caf6e",
        "#ffd54f",
        "#42a5f5",
        "#ff7043",
        "#808080",
        "#808080"
      ],
      "optionLabels": [
        "Raw (×1.00)",
        "Baked (×0.75)",
        "Boiled (×0.50)",
        "Dried (×0.25)",
        "Burned (×0.00)",
        "Rotten (×0.00)"
      ]
    }
  ],
  "tutorialSteps": [
    {
      "title": "💰 Item Price Thresholds",
      "demoValues": {
        "maxPrice": "1000",
        "maxStock": "100",
        "minPrice": "100",
        "minStock": "1"
      },
      "description": "Set MinPrice and MaxPrice to define the buy price range. MinPrice is what the trader charges when stock is at MaxStock (abundant = cheap). MaxPrice is charged at MinStock (scarce = expensive).",
      "highlightSelector": "[data-tutorial='tpl-sec-item']"
    },
    {
      "title": "📊 Zone / Global Percentages",
      "demoValues": {
        "buyPercent": "100",
        "sellPercent": "50"
      },
      "description": "SellPricePercent controls how much players get when selling (as % of buy price). BuyPricePercent is a zone-level multiplier on all buy prices. Set sell to -1 to make items non-sellable.",
      "highlightSelector": "[data-tutorial='tpl-sec-zone']"
    },
    {
      "title": "🔧 Sell Modifiers",
      "demoValues": {
        "isEdible": "true",
        "condition": "Damaged",
        "foodStage": "baked",
        "quantityRatio": "50"
      },
      "description": "Item condition (Pristine → Ruined), quantity percentage, and food stage all reduce the sell price. A Damaged item at 50% quantity sells for much less than a Pristine full one.",
      "highlightSelector": "[data-tutorial='tpl-sec-sell']"
    },
    {
      "title": "📈 Results & Price Curve",
      "demoValues": {
        "isEdible": "false",
        "condition": "Pristine",
        "quantityRatio": "100"
      },
      "description": "The summary cards show current buy/sell prices and the spread (profit margin). The chart plots buy and sell prices across all stock levels so you can visualize the pricing curve.",
      "highlightSelector": "[data-tutorial='tpl-right']"
    }
  ],
